{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/panthalnet/arike/specs/004-arike-app-icon/contracts/manifest.schema.json",
  "title": "Arike PWA Web App Manifest",
  "description": "Contract for the Next.js manifest.ts output (served at /manifest.webmanifest). Validated against Web App Manifest W3C spec and Chrome/Safari PWA install criteria.",
  "type": "object",
  "required": ["name", "short_name", "start_url", "display", "icons"],
  "properties": {
    "name": {
      "type": "string",
      "const": "Arike",
      "description": "Full application name shown during PWA install prompt"
    },
    "short_name": {
      "type": "string",
      "const": "Arike",
      "description": "Short name shown on home screen icon label (max 12 chars recommended)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the application"
    },
    "start_url": {
      "type": "string",
      "const": "/",
      "description": "URL opened when the installed PWA is launched"
    },
    "display": {
      "type": "string",
      "enum": ["standalone", "fullscreen", "minimal-ui", "browser"],
      "const": "standalone",
      "description": "Display mode; 'standalone' removes browser chrome when installed"
    },
    "background_color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "Background color shown during splash screen before app CSS loads"
    },
    "theme_color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "Browser UI chrome color (tab bar, status bar)"
    },
    "icons": {
      "type": "array",
      "minItems": 2,
      "description": "Icon set used for home screen and splash screen. Must include 192×192 and 512×512.",
      "items": {
        "type": "object",
        "required": ["src", "sizes", "type"],
        "properties": {
          "src": {
            "type": "string",
            "description": "Absolute path or URL to the icon file"
          },
          "sizes": {
            "type": "string",
            "pattern": "^[0-9]+x[0-9]+$",
            "description": "Icon dimensions in the format WxH (e.g., '192x192')"
          },
          "type": {
            "type": "string",
            "enum": ["image/png", "image/svg+xml", "image/webp"],
            "description": "MIME type of the icon"
          },
          "purpose": {
            "type": "string",
            "enum": ["any", "maskable", "monochrome"],
            "description": "Icon purpose; 'maskable' required for Android adaptive icons"
          }
        }
      },
      "contains": {
        "type": "object",
        "properties": {
          "sizes": { "const": "192x192" }
        },
        "required": ["sizes"]
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": { "sizes": { "const": "192x192" } },
            "required": ["sizes"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": { "sizes": { "const": "512x512" } },
            "required": ["sizes"]
          }
        }
      ]
    }
  },
  "examples": [
    {
      "name": "Arike",
      "short_name": "Arike",
      "description": "Self-hosted browser startup page and personal dashboard",
      "start_url": "/",
      "display": "standalone",
      "background_color": "#0f0f1a",
      "theme_color": "#1a1a2e",
      "icons": [
        { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" },
        { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png" },
        { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
      ]
    }
  ]
}
